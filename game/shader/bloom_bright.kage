//kage:unit pixels

package main

// Brightness extraction — low threshold to catch all neon elements.
var Threshold float

func Fragment(dstPos vec4, srcPos vec2, color vec4) vec4 {
	c := imageSrc0At(srcPos)
	brightness := dot(c.rgb, vec3(0.2126, 0.7152, 0.0722))
	if brightness < Threshold {
		return vec4(0)
	}
	// Boost extracted brightness for fat glow.
	factor := (brightness - Threshold) / (1.0 - Threshold)
	return c * factor * 1.5
}
